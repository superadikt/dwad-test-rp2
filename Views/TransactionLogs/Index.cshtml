@model IEnumerable<DwadTestRp.Models.TransactionLog>

@{
    ViewData["Title"] = "Transaction Logs";
}

<h1>Transaction Logs</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Timestamp</th>
            <th>Action</th>
            <th>Entity</th>
            <th>Entity ID</th>
            <th>Performed By</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Id</td>
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                    @{
                        var badgeClass = log.Action switch
                        {
                            "Create" => "bg-success",
                            "Update" => "bg-primary",
                            "Delete" => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass">@log.Action</span>
                </td>
                <td>@log.Entity</td>
                <td>@log.EntityId</td>
                <td>@log.PerformedBy</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>
